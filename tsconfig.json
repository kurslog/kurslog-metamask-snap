{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "jsx": "react-jsx",
    "jsxImportSource": "@metamask/snaps-sdk"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "test"]
}
